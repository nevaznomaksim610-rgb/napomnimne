# ── Telegram ────────────────────────────────────────────────
# Токен от @BotFather
BOT_TOKEN=123456:ABC-DEF...

# Твой telegram_id — на него агент шлёт уведомления (узнать у @userinfobot)
ADMIN_CHAT_ID=0

# ── DeepSeek (анализ писем) ─────────────────────────────────
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ── Почтовый ящик агента (рассылка + чтение ответов) ────────
EMAIL_ADDRESS=
EMAIL_PASSWORD=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
IMAP_HOST=imap.gmail.com
IMAP_PORT=993

# ── База данных ─────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./bot.db

# ── Параметры рассылки агента ───────────────────────────────
# через сколько дней слать follow-up, если нет ответа
FOLLOWUP_DELAY_DAYS=3
# максимум follow-up писем до перевода в STALLED
MAX_FOLLOWUPS=2
# за сколько дней до дедлайна напоминать пользователю
REMINDER_OFFSET_DAYS=7
